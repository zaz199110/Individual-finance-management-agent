# ============================================================
# 金融顾问 Agent — 环境变量模板
# 复制为 .env.local 后填入真实密钥
# 注意：.env.local 不会被 Git 跟踪，请勿在 .env.example 中写入真实密钥
# ============================================================
#
# 两种部署模式（代码自动根据 SUPABASE_URL 切换）：
#   本地 Demo：SUPABASE_URL=http://127.0.0.1:54321
#   BYOK 云端：SUPABASE_URL=https://your-project.supabase.co
# 详见 README.md「部署模式」

# ---------- Supabase（关系型数据库）----------
# 本地 Demo（npm run supabase:start 后填入 CLI 输出的密钥）：
# SUPABASE_URL=http://127.0.0.1:54321
# SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_ROLE_KEY=
# SUPABASE_DB_PASSWORD=postgres
# DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres
# 向量库（与主库相同即可）：
# VECTOR_SUPABASE_URL=
# VECTOR_SUPABASE_ANON_KEY=

# BYOK 云端（填入你的 Supabase 项目信息）：
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_DB_PASSWORD=your-db-password
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.your-project.supabase.co:5432/postgres

# ---------- 推理模型（主对话 / Agent）----------
LLM_API_URL=https://api.deepseek.com/v1
LLM_API_KEY=sk-your-deepseek-key
LLM_MODEL_NAME=deepseek-chat

# ---------- 图片理解 / 多模态（可选，无则跳过）----------
# VISION_API_URL=https://token-plan-cn.xiaomimimo.com/anthropic
# VISION_API_KEY=your-mimo-key
# VISION_MODEL_NAME=mimo-v2.5

# ---------- 小米 Mimo（Anthropic 兼容 · 可选备选）----------
# MIMO_API_URL=https://token-plan-cn.xiaomimimo.com/anthropic
# MIMO_API_KEY=your-mimo-key
# MIMO_MODEL_NAME=mimo-v2.5
# MIMO_API_PROTOCOL=anthropic

# ---------- 备用：Kimi ----------
# KIMI_API_URL=https://api.moonshot.cn/v1
# KIMI_API_KEY=sk-your-kimi-key
# KIMI_MODEL_NAME=moonshot-v1-8k

# ---------- 智谱（联网搜索 + 文本嵌入 · 可选）----------
# ZHIPU_API_KEY=your-zhipu-key

# ---------- 金融数据（L0 · Tushare Token · 可选）----------
# TUSHARE_TOKEN=your-tushare-token

# ---------- 应用 ----------
APP_ENV=development
APP_SECRET=change-me-to-a-random-string
