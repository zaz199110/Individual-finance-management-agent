# ============================================================
# 金融顾问 Agent — 环境变量模板（无真实密钥）
# 复制为项目根目录 .env.local（勿提交 Git）
# ============================================================
#
# 部署模式（同一套代码，由 SUPABASE_URL 自动切换）：
#   路径 A · 本地 Demo：SUPABASE_URL=http://127.0.0.1:54321（npx supabase start 输出）
#   路径 B · BYOK 云端：SUPABASE_URL=https://your-project.supabase.co
# 详见 README.md「部署模式」与 requirement/prd/02-settings-database.md §2.3.0
#

# ---------- Supabase（关系型数据库 · 路径 A 示例）----------
# 本地 Demo（npx supabase start 后填入 CLI 输出）：
# SUPABASE_URL=http://127.0.0.1:54321
# SUPABASE_ANON_KEY=eyJhbGci...（本地 demo anon）
# SUPABASE_SERVICE_ROLE_KEY=eyJhbGci...（本地 demo service_role）
# SUPABASE_DB_PASSWORD=postgres
# DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres
# VECTOR_SUPABASE_URL=http://127.0.0.1:54321
# VECTOR_SUPABASE_ANON_KEY=（与 SUPABASE_ANON_KEY 相同）

# ---------- Supabase（路径 B · BYOK 云端）----------
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_DB_PASSWORD=your-db-password
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD_ENCODED@db.your-project.supabase.co:5432/postgres

# ---------- 向量库（KB-02：Supabase pgvector 语义子库 · 仅 FAQ · §3.5.6）----------
# 披露 FTS：本地 data/fund-knowledge/ + index.db（KB-01）
# VECTOR_SUPABASE_URL=
# VECTOR_SUPABASE_ANON_KEY=

# ---------- 推理模型（主对话 / Agent）----------
LLM_API_URL=https://api.deepseek.com/v1
LLM_API_KEY=sk-your-deepseek-key
LLM_MODEL_NAME=deepseek-chat

# ---------- 图片理解 / 多模态（默认与推理相同 = Mimo v2.5）----------
# VISION_API_URL=https://token-plan-cn.xiaomimimo.com/anthropic
# VISION_API_KEY=your-mimo-key
# VISION_MODEL_NAME=mimo-v2.5

# ---------- 向量 Rerank（本期不做 · KB-01）----------
# RERANK_API_URL=
# RERANK_API_KEY=
# RERANK_MODEL_NAME=

# ---------- 备用：Kimi ----------
KIMI_API_URL=https://api.moonshot.cn/v1
KIMI_API_KEY=sk-your-kimi-key
KIMI_MODEL_NAME=moonshot-v1-8k

# ---------- 小米 Mimo（Token Plan · Anthropic 兼容）----------
# 控制台 Base URL：https://token-plan-cn.xiaomimimo.com/anthropic
# OpenAI 兼容备选：https://token-plan-cn.xiaomimimo.com/v1
MIMO_API_URL=https://token-plan-cn.xiaomimimo.com/anthropic
MIMO_API_KEY=your-mimo-key
MIMO_MODEL_NAME=mimo-v2.5
MIMO_API_PROTOCOL=anthropic

# ---------- 智谱（联网 Search-Std · 资源包按次计费）----------
# API 文档：https://docs.bigmodel.cn/api-reference/工具-api/网络搜索
ZHIPU_WEB_API_URL=https://open.bigmodel.cn/api
ZHIPU_WEB_SEARCH_ENGINE=search_std

# ---------- 智谱（文本嵌入 Embedding-3 · 可选，聊天不依赖）----------
# API 文档：https://docs.bigmodel.cn/api-reference/模型-api/文本嵌入
ZHIPU_EMBEDDING_API_URL=https://open.bigmodel.cn/api/paas/v4
ZHIPU_EMBEDDING_MODEL=embedding-3

# 智谱通用 API Key（联网 / 嵌入共用）
ZHIPU_API_KEY=your-zhipu-key

# ---------- 金融数据（L0 · 推荐在 设置→数据源 页配置；此处供维护者联调）----------
TUSHARE_TOKEN=your-tushare-token

# ---------- 应用 ----------
APP_ENV=development
APP_SECRET=change-me-to-random-string
